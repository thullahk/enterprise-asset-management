<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Multi-company rule for account.asset -->
        <record id="account_asset_comp_rule" model="ir.rule">
            <field name="name">Account Asset: multi-company</field>
            <field name="model_id" ref="model_account_asset"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Multi-company rule for account.asset.group -->
        <record id="account_asset_group_comp_rule" model="ir.rule">
            <field name="name">Account Asset Group: multi-company</field>
            <field name="model_id" ref="model_account_asset_group"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
