<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Entry / Bill form view inherit to add Asset button -->
    <record id="view_move_form_asset_inherit" model="ir.ui.view">
        <field name="name">account.move.form.asset.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" name="action_open_asset_ids"
                        type="object" icon="fa-id-card-o" 
                        attrs="{'invisible': [('count_asset', '=', 0)]}">
                    <field name="count_asset" widget="statinfo" string="Assets"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
